	virtual void ClosePvrFile( HANDLE FileHandle ) = 0;
	virtual unsigned long ReadPvrFile( HANDLE fileHandle, unsigned char *Data, unsigned long Length) = 0;
	virtual HANDLE OpenPvrFile( char *FileName ) = 0;
	//HDDPVR();
	//virtual ~HDDPVR();

